{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist-electron",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": ["node", "electron"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.d.ts"
  ]
}
